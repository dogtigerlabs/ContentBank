@prefix tl:     <https://tinylibrary.io/ns#> .
@prefix sh:     <http://www.w3.org/ns/shacl#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:    <http://www.w3.org/2002/07/owl#> .

# =============================================================================
# TinyLibrary ContentBank — Core Ontology and SHACL Shapes
# Namespace: https://tinylibrary.io/ns#
# Version: 0.1.0 (2026-03-16)
# =============================================================================


# -----------------------------------------------------------------------------
# Scope — ordered from least to most restrictive
#
# tl:Individual and tl:Community are singleton named individuals.
# tl:Family and tl:Group are tl:ScopeGroup instances (membership lists).
# Each deployment creates its own ScopeGroup instances (urn:cb:scope_group:{uuid}).
#
# Scope order for transitivity constraint:
#   Community(0) < Group(1) < Family(2) < Individual(3)
# -----------------------------------------------------------------------------

tl:Scope a rdfs:Class ;
    rdfs:comment "Base class for scope values. Either a singleton (Individual, Community) or a tl:ScopeGroup instance." .

tl:scopeOrder a owl:DatatypeProperty ;
    rdfs:domain tl:Scope ;
    rdfs:range  xsd:integer ;
    rdfs:comment "Numeric ordering of scope restrictiveness. Higher = more restrictive." .

# Singleton scopes (no membership list needed)
tl:Community  a tl:Scope ; rdfs:label "Community" ;  tl:scopeOrder 0 .
tl:Individual a tl:Scope ; rdfs:label "Individual" ;  tl:scopeOrder 3 .


# -----------------------------------------------------------------------------
# ScopeGroup — a named group of Agents with a defined scope level
#
# Instances are created per deployment (urn:cb:scope_group:{uuid}).
# tl:groupType determines the scope order for transitivity enforcement:
#   "group"  → scopeOrder 1
#   "family" → scopeOrder 2
# -----------------------------------------------------------------------------

tl:ScopeGroup a rdfs:Class ;
    rdfs:subClassOf tl:Scope ;
    rdfs:comment "A named group of Agents. Used as the tl:scope value on Objects with Family or Group visibility. Membership defined by tl:member." .

tl:ScopeGroupShape a sh:NodeShape ;
    sh:targetClass tl:ScopeGroup ;
    sh:closed false ;

    sh:property [
        sh:path     tl:id ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:pattern  "^urn:cb:scope_group:[0-9a-f-]{36}$" ;
        sh:message  "ScopeGroup IRI must follow urn:cb:scope_group:{uuid}." ;
    ] ;

    sh:property [
        sh:path     tl:name ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:comment  "Human-readable name for this group (e.g. 'Hernandez Family', 'Water District Team')." ;
    ] ;

    sh:property [
        sh:path     tl:groupType ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:in       ( "family" "group" ) ;
        sh:comment  "Determines scope order: 'group' = 1, 'family' = 2." ;
    ] ;

    sh:property [
        sh:path     tl:member ;
        sh:class    tl:Agent ;
        sh:minCount 1 ;
        sh:comment  "One or more Agents who are members of this group." ;
    ] ;

    sh:property [
        sh:path     tl:createdAt ;
        sh:datatype xsd:dateTime ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path     tl:updatedAt ;
        sh:datatype xsd:dateTime ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] .


# -----------------------------------------------------------------------------
# BlobAttachment — binary data linked via IPFS CID
# -----------------------------------------------------------------------------

tl:BlobAttachment a rdfs:Class ;
    rdfs:comment "A binary attachment linked from a ContentBank Object via an IPFS CID." .

tl:BlobRole a rdfs:Class ;
    rdfs:comment "Role played by a blob attachment." .

tl:primary    a tl:BlobRole ; rdfs:label "primary" .
tl:thumbnail  a tl:BlobRole ; rdfs:label "thumbnail" .
tl:raw        a tl:BlobRole ; rdfs:label "raw" .
tl:transcript a tl:BlobRole ; rdfs:label "transcript" .
tl:preview    a tl:BlobRole ; rdfs:label "preview" .

tl:BlobAttachmentShape a sh:NodeShape ;
    sh:targetClass tl:BlobAttachment ;
    sh:closed false ;

    sh:property [
        sh:path     tl:cid ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:pattern  "^bafy[a-z2-7]+" ;
        sh:message  "tl:cid must be a valid IPFS CIDv1 (base32, bafy prefix)." ;
    ] ;

    sh:property [
        sh:path     tl:mimeType ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message  "tl:mimeType is required on every BlobAttachment." ;
    ] ;

    sh:property [
        sh:path     tl:blobRole ;
        sh:class    tl:BlobRole ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message  "tl:blobRole is required and must be a tl:BlobRole individual." ;
    ] ;

    sh:property [
        sh:path     tl:byteSize ;
        sh:datatype xsd:long ;
        sh:minCount 0 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path     tl:contentHash ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:comment  "Optional SHA-256 hex digest for out-of-band verification." ;
    ] .


# -----------------------------------------------------------------------------
# Object — base class for all ContentBank objects
# -----------------------------------------------------------------------------

tl:Object a rdfs:Class ;
    rdfs:comment "Base class for all ContentBank objects. All Capability types extend this class." .

tl:ObjectShape a sh:NodeShape ;
    sh:targetClass tl:Object ;
    sh:closed false ;   # Open: Capability shapes add properties via sh:property on subclasses

    # --- Identity ---
    sh:property [
        sh:path     tl:id ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:pattern  "^urn:cb:[a-z][a-z0-9_-]+:[0-9a-f-]{36}$" ;
        sh:message  "tl:id must follow the pattern urn:cb:{type}:{uuid}." ;
    ] ;

    # --- Type slug (mirrors the type segment of the ID for filtering) ---
    sh:property [
        sh:path     tl:typeSlug ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:pattern  "^[a-z][a-z0-9_-]+$" ;
        sh:message  "tl:typeSlug must be a lowercase identifier (e.g. 'photograph', 'calendar_event')." ;
    ] ;

    # --- Ownership ---
    # Owner may be a tl:Agent (individual) or a tl:ScopeGroup (family/group).
    # Ownership governs storage allocation and write rights.
    # Scope governs read visibility and must be equal to or broader than ownership.
    sh:property [
        sh:path     tl:owner ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:or (
            [ sh:class tl:Agent ]
            [ sh:class tl:ScopeGroup ]
        ) ;
        sh:message  "tl:owner must be a tl:Agent or tl:ScopeGroup IRI." ;
    ] ;

    # --- Scope ---
    # tl:Individual and tl:Community → singleton tl:Scope named individuals
    # Family / Group visibility → IRI of a tl:ScopeGroup instance
    sh:property [
        sh:path     tl:scope ;
        sh:class    tl:Scope ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message  "tl:scope is required. Use tl:Individual or tl:Community for singleton scopes, or a tl:ScopeGroup IRI for family/group visibility." ;
    ] ;

    # --- Timestamps ---
    sh:property [
        sh:path     tl:createdAt ;
        sh:datatype xsd:dateTime ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path     tl:updatedAt ;
        sh:datatype xsd:dateTime ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    # --- Provenance ---
    sh:property [
        sh:path     tl:sourceNode ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:comment  "Node ID where this object was originally created." ;
    ] ;

    sh:property [
        sh:path     tl:contentHash ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:comment  "SHA-256 of the canonical serialization of this object (excluding blobs). Tracks current state for replication verification." ;
    ] ;

    # --- Blob attachments ---
    sh:property [
        sh:path     tl:blob ;
        sh:class    tl:BlobAttachment ;
        sh:minCount 0 ;
        sh:comment  "Zero or more binary attachments. Each attachment has a role, CID, and MIME type." ;
    ] ;

    # --- Capability extension point ---
    sh:property [
        sh:path     tl:capabilityMetadata ;
        sh:nodeKind sh:BlankNodeOrIRI ;
        sh:maxCount 1 ;
        sh:comment  "Extension point for Capability-specific metadata nodes. Capability shapes constrain this further." ;
    ] .


# -----------------------------------------------------------------------------
# Scope transitivity constraint
# A tl:Object MUST NOT reference another tl:Object with a more restrictive scope.
# Scope order: Community(0) < Group(1) < Family(2) < Individual(3)
# A 'more restrictive' reference means: scope(target).scopeOrder > scope(source).scopeOrder
# -----------------------------------------------------------------------------

tl:ScopeTransitivityConstraint a sh:NodeShape ;
    sh:targetClass tl:Object ;
    sh:sparql [
        sh:message "An Object must not reference another Object with a more restrictive scope (scope leak across graph boundary)." ;
        sh:select """
            PREFIX tl: <https://tinylibrary.io/ns#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

            SELECT $this ?referencedObject
            WHERE {
                $this tl:scope ?sourceScope .

                # Resolve source scope order:
                # Singleton scopes carry tl:scopeOrder directly.
                # ScopeGroup instances derive order from tl:groupType.
                BIND(
                    IF(EXISTS { ?sourceScope tl:scopeOrder ?x },
                        ?x,
                        IF(EXISTS { ?sourceScope tl:groupType "family" },
                            2,
                            IF(EXISTS { ?sourceScope tl:groupType "group" },
                                1,
                                0
                            )
                        )
                    )
                AS ?sourceOrder)

                $this ?anyProp ?referencedObject .
                ?referencedObject a tl:Object ;
                                  tl:scope ?targetScope .

                # Resolve target scope order
                BIND(
                    IF(EXISTS { ?targetScope tl:scopeOrder ?y },
                        ?y,
                        IF(EXISTS { ?targetScope tl:groupType "family" },
                            2,
                            IF(EXISTS { ?targetScope tl:groupType "group" },
                                1,
                                0
                            )
                        )
                    )
                AS ?targetOrder)

                FILTER (?targetOrder > ?sourceOrder)
            }
        """ ;
    ] .


# -----------------------------------------------------------------------------
# Ownership/scope compatibility constraint
#
# Scope must be equal to or broader than ownership.
# Scope order: Community(0) < Group(1) < Family(2) < Individual(3)
# Owner scope order: Agent → Individual(3), ScopeGroup → groupType order
#
# Rule: scopeOrder(scope) <= ownerScopeOrder
# i.e. scope must not be MORE restrictive than the owner's implicit scope level
# -----------------------------------------------------------------------------

tl:OwnerScopeCompatibilityConstraint a sh:NodeShape ;
    sh:targetClass tl:Object ;
    sh:sparql [
        sh:message "tl:scope must be equal to or broader than tl:owner (scope cannot be more restrictive than ownership)." ;
        sh:select """
            PREFIX tl: <https://tinylibrary.io/ns#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

            SELECT $this
            WHERE {
                $this tl:scope ?scope ;
                      tl:owner ?owner .

                # Resolve scope order
                BIND(
                    IF(EXISTS { ?scope tl:scopeOrder ?so }, ?so,
                        IF(EXISTS { ?scope tl:groupType "family" }, 2,
                            IF(EXISTS { ?scope tl:groupType "group" }, 1, 0)
                        )
                    )
                AS ?scopeOrder)

                # Resolve owner's implicit scope order:
                # tl:Agent owner → Individual = 3
                # tl:ScopeGroup owner → derived from groupType
                BIND(
                    IF(EXISTS { ?owner a tl:Agent }, 3,
                        IF(EXISTS { ?owner tl:groupType "family" }, 2,
                            IF(EXISTS { ?owner tl:groupType "group" }, 1, 0)
                        )
                    )
                AS ?ownerOrder)

                # Violation: scope is more restrictive than owner
                FILTER (?scopeOrder > ?ownerOrder)
            }
        """ ;
    ] .


# -----------------------------------------------------------------------------
# Agent — represents a user or system agent that owns/creates Objects
# -----------------------------------------------------------------------------

tl:Agent a rdfs:Class ;
    rdfs:comment "A user or system agent. Owns and creates ContentBank Objects." .

tl:AgentShape a sh:NodeShape ;
    sh:targetClass tl:Agent ;
    sh:closed false ;

    sh:property [
        sh:path     tl:id ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:pattern  "^urn:cb:agent:[0-9a-f-]{36}$" ;
        sh:message  "Agent IRI must follow urn:cb:agent:{uuid}." ;
    ] ;

    sh:property [
        sh:path     tl:displayName ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path     tl:publicKey ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:comment  "ECDH public key (base64url) for secure pairing and permission binding." ;
    ] ;

    sh:property [
        sh:path     tl:createdAt ;
        sh:datatype xsd:dateTime ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] .


# -----------------------------------------------------------------------------
# Node — represents a TinyLibrary node in the mesh
# -----------------------------------------------------------------------------

tl:Node a rdfs:Class ;
    rdfs:comment "A TinyLibrary node — a device or server participating in the ContentBank mesh." .

tl:NodeShape a sh:NodeShape ;
    sh:targetClass tl:Node ;
    sh:closed false ;

    sh:property [
        sh:path     tl:id ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:pattern  "^urn:cb:node:[0-9a-f-]{36}$" ;
    ] ;

    sh:property [
        sh:path     tl:displayName ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path     tl:nodeType ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:in       ( "edge" "cloud" "gateway" ) ;
        sh:comment  "edge = RPi/SBC; cloud = DO droplet etc.; gateway = mesh bridge node." ;
    ] ;

    sh:property [
        sh:path     tl:publicKey ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path     tl:lastSeenAt ;
        sh:datatype xsd:dateTime ;
        sh:maxCount 1 ;
    ] .
